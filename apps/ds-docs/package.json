{
  "name": "ds-docs",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "description": "Azion Design System Documentation Platform",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "pnpm build:search && pnpm build:api && pnpm build:scaffold && astro build",
    "build:search": "tsx scripts/build-search-index.ts",
    "build:api": "tsx scripts/extractComponentApi.ts",
    "build:api:webkit": "tsx scripts/extractComponentApi.ts --webkit-source=../../packages/webkit/src/core",
    "build:scaffold": "tsx scripts/scaffoldComponentDocs.ts",
    "build:scaffold:dry": "tsx scripts/scaffoldComponentDocs.ts --dry-run --verbose",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "node --loader ts-node/esm scripts/check-docs.ts lint",
    "lint:links": "node --loader ts-node/esm scripts/check-docs.ts links",
    "lint:rules": "node --loader ts-node/esm scripts/check-docs.ts rules",
    "lint:coverage": "node --loader ts-node/esm scripts/checkComponentDocs.ts",
    "check": "node --loader ts-node/esm scripts/check-docs.ts all",
    "changelog": "node --loader ts-node/esm scripts/generateChangelog.ts"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.13",
    "@aziontech/icons": "workspace:*",
    "@aziontech/theme": "workspace:*",
    "@aziontech/webkit": "workspace:*",
    "@vueuse/core": "^10.11.1",
    "astro": "^5.4.0",
    "motion": "^12.35.2",
    "motion-v": "^2.0.0",
    "primevue": "3.35.0",
    "shiki": "^4.0.2",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.29"
  },
  "devDependencies": {
    "sass": "^1.77.0",
    "@astrojs/tailwind": "^6.0.2",
    "@astrojs/vue": "^5.0.6",
    "@tailwindcss/typography": "^0.5.19",
    "autoprefixer": "^10.4.27",
    "tailwindcss": "^3.4.19",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
