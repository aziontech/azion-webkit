---
/**
 * ComponentUsageTab
 * 
 * Renders the Usage tab content for component documentation.
 * 
 * Content order:
 * 1. When to use
 * 2. Dos and don'ts
 * 3. Examples
 * 
 * Supports both structured frontmatter data and slot content.
 */

import type { UsageMetadata } from '../../content/config';
import ExampleBlock from './ExampleBlock.astro';
import ComponentPreview from './ComponentPreview.vue';

interface Props {
  /** Component name for section IDs */
  component?: string;
  /** Structured usage data from frontmatter */
  usage?: UsageMetadata;
}

const { component = 'component', usage } = Astro.props;

// Map component names to their string identifiers for the preview
const componentNameMap: Record<string, string> = {
  AzButton: 'AzButton',
  toast: 'BlockToastDemo',
  BlockToastDemo: 'BlockToastDemo',
};

// Get the component name for previews
const previewComponentName = componentNameMap[component] || component;

// Check if we have structured usage data
const hasStructuredUsage = usage && (
  (usage.whenToUse && usage.whenToUse.length > 0) ||
  (usage.whenNotToUse && usage.whenNotToUse.length > 0) ||
  (usage.doDonts && usage.doDonts.length > 0) ||
  (usage.examples && usage.examples.length > 0)
);

// Separate do's and don'ts
const dos = usage?.doDonts?.filter(item => item.type === 'do') || [];
const donts = usage?.doDonts?.filter(item => item.type === 'dont') || [];
---

<div class="component-usage-tab">
  {hasStructuredUsage ? (
    <!-- Render structured usage data -->
    <div class="usage-content">
      <!-- When to Use -->
      {usage?.whenToUse && usage.whenToUse.length > 0 && (
        <section class="usage-section" id={`${component}-when-to-use`}>
          <h2>When to Use</h2>
          <ul class="usage-list">
            {usage.whenToUse.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </section>
      )}

      <!-- When Not to Use -->
      {usage?.whenNotToUse && usage.whenNotToUse.length > 0 && (
        <section class="usage-section" id={`${component}-when-not-to-use`}>
          <h2>When Not to Use</h2>
          <ul class="usage-list">
            {usage.whenNotToUse.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </section>
      )}

      <!-- Do's and Don'ts -->
      {usage?.doDonts && usage.doDonts.length > 0 && (
        <section class="usage-section" id={`${component}-dos-and-donts`}>
          <h2>Do's and Don'ts</h2>
          <div class="do-dont-grid">
            {/* Do's column */}
            {dos.length > 0 && (
              <div class="do-dont__do rounded-lg border-2 border-green-200 bg-green-50 overflow-hidden">
                <div class="do-dont__header px-4 py-2 bg-green-100 border-b border-green-200 flex items-center gap-2">
                  <i class="pi pi-check w-5 h-5 text-green-600" aria-hidden="true" />
                  <span class="text-sm font-medium text-green-700">Do</span>
                </div>
                <div class="do-dont__content p-4 space-y-3">
                  {dos.map((item) => (
                    <div class="do-dont__item">
                      <p class="text-sm text-gray-700 mb-2">{item.description}</p>
                      {item.example && (
                        <div class="do-dont__preview flex items-center gap-2 mb-2">
                          <ComponentPreview
                            client:load
                            code={item.example}
                            componentName={previewComponentName}
                          />
                        </div>
                      )}
                      {/* {item.example && (
                        <code class="mt-1 text-xs bg-green-100 px-1.5 py-0.5 rounded block">{item.example}</code>
                      )} */}
                    </div>
                  ))}
                </div>
              </div>
            )}
            
            {/* Don'ts column */}
            {donts.length > 0 && (
              <div class="do-dont__dont rounded-lg border-2 border-red-200 bg-red-50 overflow-hidden">
                <div class="do-dont__header px-4 py-2 bg-red-100 border-b border-red-200 flex items-center gap-2">
                  <i class="pi pi-times w-5 h-5 text-red-600" aria-hidden="true" />
                  <span class="text-sm font-medium text-red-700">Don't</span>
                </div>
                <div class="do-dont__content p-4 space-y-3">
                  {donts.map((item) => (
                    <div class="do-dont__item">
                      <p class="text-sm text-gray-700 mb-2">{item.description}</p>
                      {item.example && (
                        <div class="do-dont__preview flex items-center gap-2 mb-2">
                          <ComponentPreview
                            client:load
                            code={item.example}
                            componentName={previewComponentName}
                          />
                        </div>
                      )}
                      {/* {item.example && (
                        <code class="mt-1 text-xs bg-red-100 px-1.5 py-0.5 rounded block">{item.example}</code>
                      )} */}
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>
        </section>
      )}

      <!-- Examples -->
      {usage?.examples && usage.examples.length > 0 && (
        <section class="usage-section" id={`${component}-examples`}>
          <h2>Examples</h2>
          {usage.examples.map((example) => (
            <ExampleBlock
              title={example.title}
              description={example.description}
              code={example.code}
            >
              {example.preview ? (
                <Fragment set:html={example.preview} />
              ) : (
                <ComponentPreview
                  client:load
                  code={example.code}
                  componentName={previewComponentName}
                />
              )}
            </ExampleBlock>
          ))}
        </section>
      )}
    </div>
  ) : (
    <!-- Fallback to slot content for markdown-authored usage, or empty state -->
    <div class="usage-content usage-content--fallback">
      <slot />
      <div class="empty-usage-state py-12 text-center border border-dashed border-default rounded-lg bg-surface">
        <i class="pi pi-book mx-auto text-4xl text-muted" aria-hidden="true" />
        <h3 class="mt-2 text-sm font-medium text-default">Usage documentation coming soon</h3>
        <p class="mt-1 text-sm text-muted">
          When to use, do's and don'ts, and examples will be available shortly.
        </p>
      </div>
    </div>
  )}
</div>

<style>
  /* Section styling for consistent spacing */
  .usage-content :global(h2) {
    @apply text-2xl font-medium dark:text-white text-black tracking-tight mt-10 mb-2 pb-2;
  }
  
  .usage-content :global(h3) {
    @apply text-xl font-medium dark:text-white text-black mt-8 mb-3;
  }
  
  .usage-content :global(h4) {
    @apply text-lg font-medium dark:text-white text-black mt-6 mb-2;
  }
  
  /* Paragraph spacing */
  .usage-content :global(p) {
    @apply mb-4 leading-relaxed text-muted dark:text-[#a3a3a3];
  }
  
  /* List styling */
  .usage-content :global(ul),
  .usage-content :global(ol) {
    @apply mb-4 pl-6;
  }
  
  .usage-content :global(li) {
    @apply mb-2 text-muted dark:text-[#a3a3a3];
  }
  
  /* Link styling */
  .usage-content :global(a) {
    @apply text-link hover:text-link-hover underline underline-offset-2;
  }
  
  /* Code styling */
  .usage-content :global(code) {
    @apply bg-gray-100 px-1.5 py-0.5 rounded text-sm font-code;
  }
  
  .usage-content :global(pre) {
    @apply bg-surface-900 text-gray-100 p-4 rounded-lg overflow-x-auto my-4;
  }
  
  .usage-content :global(pre code) {
    @apply bg-transparent p-0;
  }

  /* Usage section spacing */
  .usage-section {
    @apply mb-8;
  }

  .usage-section:last-child {
    @apply mb-0;
  }

  /* Usage list styling */
  .usage-list {
    @apply list-disc pl-6 space-y-2;
  }

  .usage-list li {
    @apply text-muted dark:text-[#a3a3a3] leading-relaxed;
  }

  /* Do/Don't grid */
  .do-dont-grid {
    @apply grid gap-4;
  }

  @screen md {
    .do-dont-grid {
      @apply grid-cols-2;
    }
  }

  /* Do/Don't item spacing */
  .do-dont__item {
    @apply last:mb-0;
  }

  /* Hide empty state when slot has content (slot content is rendered before .empty-usage-state) */
  .usage-content--fallback:has(> :first-child:not(.empty-usage-state)) .empty-usage-state {
    display: none;
  }
</style>
