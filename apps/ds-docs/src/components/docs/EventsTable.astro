---
/**
 * EventsTable
 * 
 * Displays component events in a structured table format.
 */

import type { EventDefinition } from '../../content/config';

interface Props {
  rows?: EventDefinition[];
  component?: string;
}

const { rows = [], component } = Astro.props;
---

<div class="events-table overflow-x-auto">
  {rows.length === 0 ? (
    <div class="empty-state py-8 text-center text-text-secondary border border-dashed border-gray-300 rounded-lg">
      <p class="text-sm">No events documented yet.</p>
    </div>
  ) : (
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="border-b border-gray-200">
          <th class="py-3 px-4 text-left font-semibold text-text-primary bg-gray-50">Event</th>
          <th class="py-3 px-4 text-left font-semibold text-text-primary bg-gray-50">Payload</th>
          <th class="py-3 px-4 text-left font-semibold text-text-primary bg-gray-50">Description</th>
        </tr>
      </thead>
      <tbody>
        {rows.map((event) => (
          <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors">
            <td class="py-3 px-4 font-code text-gray-600">
              <code class="bg-gray-100 px-1.5 py-0.5 rounded">
                @{event.name}
              </code>
            </td>
            <td class="py-3 px-4 font-code text-text-tertiary text-xs">
              {event.payload ? (
                <code class="bg-gray-100 px-1.5 py-0.5 rounded">
                  {event.payload}
                </code>
              ) : (
                <span class="text-gray-400">—</span>
              )}
            </td>
            <td class="py-3 px-4 text-text-secondary">
              {event.description}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  )}
</div>
