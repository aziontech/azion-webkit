---
/**
 * EventsTable
 * 
 * Displays component events in a structured table format.
 */

import type { EventDefinition } from '../../content/config';

interface Props {
  rows?: EventDefinition[];
  component?: string;
}

const { rows = [], component } = Astro.props;
---

<div class="events-table overflow-x-auto">
  {rows.length === 0 ? (
    <div class="empty-state py-8 text-center text-muted border border-dashed border-default rounded-lg">
      <p class="text-sm">No events documented yet.</p>
    </div>
  ) : (
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="border-b border-default">
          <th class="py-3 px-4 text-left font-medium text-default bg-layer2">Event</th>
          <th class="py-3 px-4 text-left font-medium text-default bg-layer2">Payload</th>
          <th class="py-3 px-4 text-left font-medium text-default bg-layer2">Description</th>
        </tr>
      </thead>
      <tbody>
        {rows.map((event) => (
          <tr class="border-b border-default hover:bg-layer2 transition-colors">
            <td class="py-3 px-4 font-code text-muted">
              <code class="bg-layer2 px-1.5 py-0.5 rounded">
                @{event.name}
              </code>
            </td>
            <td class="py-3 px-4 font-code text-muted text-xs">
              {event.payload ? (
                <code class="bg-layer2 px-1.5 py-0.5 rounded">
                  {event.payload}
                </code>
              ) : (
                <span class="text-muted">—</span>
              )}
            </td>
            <td class="py-3 px-4 text-muted">
              {event.description}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  )}
</div>
