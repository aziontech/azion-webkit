---
/**
 * ComponentsStatusTable Component
 * 
 * A semantic HTML table displaying component progress across design and code.
 * Supports both launched and planned components with accessible status badges.
 * 
 * Features:
 * - Semantic HTML table with proper th/td structure
 * - Zebra rows for readability
 * - Horizontal scroll on small screens
 * - Links for components with href
 * - Em dash for missing launch versions
 * - Empty state handling
 * - Column sorting with visual indicators
 */

import type { ComponentStatusItem, ProgressStatus } from '../../data/component-status';
import ProgressStatusBadge from './ProgressStatusBadge.vue';

interface Props {
  /** Array of component status items to display */
  components: ComponentStatusItem[];
  /** Optional caption explaining the table content */
  caption?: string;
}

const { 
  components, 
  caption = 'Current component maturity and planned releases.',
} = Astro.props;

// Check if we have any components to display
const hasComponents = components.length > 0;

// Status priority for sorting (lower = better)
const statusPriority: Record<ProgressStatus, number> = {
  'done': 1,
  'documenting': 2,
  'handoff': 3,
  'queued': 4,
  'planned': 5,
  'not-started': 6,
};
---

<div class="components-status-table-wrapper">
  {caption && (
    <p class="text-sm font-sans text-muted mb-4">{caption}</p>
  )}
  
  {hasComponents ? (
    <div class="overflow-x-auto">
      <table class="w-full border-collapse text-sm" data-sort-column="name" data-sort-direction="asc">
        <thead>
          <tr class="border-b font-sans border-base">
            <th 
              scope="col" 
              class="text-left py-3 px-4 font-medium text-base bg-surface-subtle cursor-pointer hover:bg-gray-100 select-none"
              data-sortable="true"
              data-column="name"
            >
              <div class="flex items-center gap-2">
                <span>Component</span>
                <span class="sort-icon mt-1 text-muted">
                  <i class="pi pi-sort-alt"/>
                </span>
              </div>
            </th>
            <th 
              scope="col" 
              class="text-left py-3 px-4 font-medium text-base bg-surface-subtle cursor-pointer hover:bg-gray-100 select-none"
              data-sortable="true"
              data-column="design"
            >
              <div class="flex items-center gap-2">
                <span>Design</span>
                <span class="sort-icon mt-1 text-muted">
                  <i class="pi pi-sort-alt"/>
                </span>
              </div>
            </th>
            <th 
              scope="col" 
              class="text-left py-3 px-4 font-medium text-base bg-surface-subtle cursor-pointer hover:bg-gray-100 select-none"
              data-sortable="true"
              data-column="code"
            >
              <div class="flex items-center gap-2">
                <span>Code</span>
                <span class="sort-icon mt-1 text-muted">
                  <i class="pi pi-sort-alt"/>
                </span>
              </div>
            </th>
            <th 
              scope="col" 
              class="text-left py-3 px-4 font-medium text-base bg-surface-subtle cursor-pointer hover:bg-gray-100 select-none"
              data-sortable="true"
              data-column="version"
            >
              <div class="flex items-center gap-2">
                <span>Launch Version</span>
                <span class="sort-icon mt-1 text-muted">
                  <i class="pi pi-sort-alt"/>
                </span>
              </div>
            </th>
          </tr>
        </thead>
        <tbody>
          {components.map((component, index) => {
            const isEven = index % 2 === 0;
            const rowClass = isEven ? 'bg-surface' : 'bg-surface-muted';
            
            return (
              <tr 
                class={`border-b border-gray-100 hover:bg-primary-50/30 transition-colors ${rowClass}`}
                data-name={component.name}
                data-design-status={component.designStatus}
                data-code-status={component.codeStatus}
                data-launch-version={component.launchVersion || ''}
              >
                <td class="py-3 px-4">
                  {component.href ? (
                    <a 
                      href={component.href}
                      class="text-primary-600 font-sans hover:text-primary-700 hover:underline focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 rounded"
                    >
                      {component.name}
                    </a>
                  ) : (
                    <span class="text-base">{component.name}</span>
                  )}
                </td>
                <td class="py-3 px-4">
                  <ProgressStatusBadge status={component.designStatus} />
                </td>
                <td class="py-3 px-4">
                  <ProgressStatusBadge status={component.codeStatus} />
                </td>
                <td class="py-3 px-4 text-muted">
                  {component.launchVersion || <span class="text-muted">—</span>}
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  ) : (
    <div class="text-center py-12 px-4 border border-base rounded-lg bg-surface-muted">
      <p class="text-muted">No components to display.</p>
      <p class="text-sm text-muted mt-1">
        Component status information will appear here once available.
      </p>
    </div>
  )}
</div>

<script>
  // Status priority for sorting (lower = better)
  const statusPriority: Record<string, number> = {
    'done': 1,
    'documenting': 2,
    'handoff': 3,
    'queued': 4,
    'planned': 5,
    'not-started': 6,
  };

  // Initialize sorting on all tables with sortable headers
  document.querySelectorAll('.components-status-table-wrapper').forEach(wrapper => {
    const table = wrapper.querySelector('table');
    if (!table) return;

    const headers = table.querySelectorAll('th[data-sortable="true"]');
    
    headers.forEach(header => {
      header.addEventListener('click', () => {
        const column = header.getAttribute('data-column');
        if (!column) return;
        
        const currentSort = table.getAttribute('data-sort-column');
        const currentDirection = table.getAttribute('data-sort-direction');
        
        // Toggle direction if same column, otherwise default to asc
        const newDirection = currentSort === column && currentDirection === 'asc' ? 'desc' : 'asc';
        
        table.setAttribute('data-sort-column', column);
        table.setAttribute('data-sort-direction', newDirection);
        
        // Update sort icons
        headers.forEach(h => {
          const icon = h.querySelector('.sort-icon');
          if (h === header) {
            icon?.classList.remove('text-muted');
            icon?.classList.add('text-primary-600');
          } else {
            icon?.classList.remove('text-primary-600');
            icon?.classList.add('text-muted');
          }
        });
        
        sortTable(table, column, newDirection);
      });
    });
  });

  function sortTable(table: HTMLTableElement, column: string, direction: string) {
    const tbody = table.querySelector('tbody');
    if (!tbody) return;
    
    const rows = Array.from(tbody.querySelectorAll('tr'));
    
    rows.sort((a, b) => {
      let comparison = 0;
      
      switch (column) {
        case 'name':
          const nameA = a.getAttribute('data-name') || '';
          const nameB = b.getAttribute('data-name') || '';
          comparison = nameA.localeCompare(nameB);
          break;
          
        case 'design':
          const designA = a.getAttribute('data-design-status') || '';
          const designB = b.getAttribute('data-design-status') || '';
          comparison = (statusPriority[designA] || 99) - (statusPriority[designB] || 99);
          break;
          
        case 'code':
          const codeA = a.getAttribute('data-code-status') || '';
          const codeB = b.getAttribute('data-code-status') || '';
          comparison = (statusPriority[codeA] || 99) - (statusPriority[codeB] || 99);
          break;
          
        case 'version':
          const versionA = a.getAttribute('data-launch-version') || '';
          const versionB = b.getAttribute('data-launch-version') || '';
          // Empty versions sort last
          if (!versionA && !versionB) comparison = 0;
          else if (!versionA) comparison = 1;
          else if (!versionB) comparison = -1;
          else comparison = versionA.localeCompare(versionB);
          break;
      }
      
      return direction === 'asc' ? comparison : -comparison;
    });
    
    // Re-append rows in new order
    rows.forEach((row, index) => {
      // Update zebra striping
      const isEven = index % 2 === 0;
      row.classList.remove('bg-surface', 'bg-surface-muted');
      row.classList.add(isEven ? 'bg-surface' : 'bg-surface-muted');
      tbody.appendChild(row);
    });
  }
</script>

<style>
  .components-status-table-wrapper {
    width: 100%;
  }
  
  /* Ensure table doesn't collapse on small screens */
  .overflow-x-auto {
    -webkit-overflow-scrolling: touch;
  }
  
  /* Minimum width for table to prevent cramping */
  table {
    min-width: 600px;
  }
  
  /* Focus styles for keyboard navigation */
  a:focus-visible {
    outline: 2px solid theme('colors.primary.500');
    outline-offset: 2px;
  }
  
  /* Improve table readability */
  th {
    position: sticky;
    top: 0;
    z-index: 1;
  }
  
  /* Sortable header hover state */
  th[data-sortable="true"] {
    user-select: none;
  }
  
  th[data-sortable="true"]:hover {
    background-color: theme('colors.gray.100');
  }
</style>
