---
/**
 * Callout
 * 
 * Highlighted information blocks for tips, warnings, and important notes.
 */

interface Props {
  type?: 'info' | 'warning' | 'error' | 'success' | 'tip' | 'note' | 'caution';
  title?: string;
}

const { type = 'info', title } = Astro.props;

const styles = {
  info: {
    bg: 'bg-blue-50',
    border: 'border-blue-200',
    icon: 'text-blue-500',
    title: 'text-blue-800',
    text: 'text-blue-700',
    iconClass: 'pi pi-info-circle',
  },
  note: {
    bg: 'bg-blue-50',
    border: 'border-blue-200',
    icon: 'text-blue-500',
    title: 'text-blue-800',
    text: 'text-blue-700',
    iconClass: 'pi pi-info-circle',
  },
  caution: {
    bg: 'bg-amber-50',
    border: 'border-amber-200',
    icon: 'text-amber-500',
    title: 'text-warning',
    text: 'text-warning',
    iconClass: 'pi pi-exclamation-triangle',
  },
  warning: {
    bg: 'bg-amber-50',
    border: 'border-amber-200',
    icon: 'text-amber-500',
    title: 'text-warning',
    text: 'text-warning',
    iconClass: 'pi pi-exclamation-triangle',
  },
  error: {
    bg: 'bg-red-50',
    border: 'border-red-200',
    icon: 'text-red-500',
    title: 'text-red-800',
    text: 'text-red-700',
    iconClass: 'pi pi-times-circle',
  },
  success: {
    bg: 'bg-green-50',
    border: 'border-green-200',
    icon: 'text-green-500',
    title: 'text-green-800',
    text: 'text-green-700',
    iconClass: 'pi pi-check-circle',
  },
  tip: {
    bg: 'bg-purple-50',
    border: 'border-purple-200',
    icon: 'text-purple-500',
    title: 'text-purple-800',
    text: 'text-purple-700',
    iconClass: 'pi pi-lightbulb',
  },
};

const style = styles[type] ?? styles.info;
---

<div class={`callout rounded-lg border ${style.bg} ${style.border} p-4 my-4`}>
  <div class="flex gap-3">
    {/* Icon */}
    <div class={`shrink-0 ${style.icon}`}>
      <i class={`${style.iconClass} text-lg`} aria-hidden="true" />
    </div>
    
    {/* Content */}
    <div class="flex-1 min-w-0">
      {title && (
        <h4 class={`text-sm font-medium ${style.title} mb-1`}>
          {title}
        </h4>
      )}
      <div class={`text-sm ${style.text}`}>
        <slot />
      </div>
    </div>
  </div>
</div>
