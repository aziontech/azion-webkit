---
import DocsLayout from '../../layouts/DocsLayout.astro';
import { getCollection } from 'astro:content';
import { markdownComponents } from '../../components/docs';
import { getBreadcrumbContext } from '../../lib/content';

/**
 * Get Started Index Page
 */

const allContent = await getCollection('v1-en');
const getStartedEntries = allContent.filter(e => (e.id || '').startsWith('get-started/'));
const indexEntry = getStartedEntries.find((e) => e.id === 'get-started/index.md' || e.id === 'get-started/index.mdx');

if (!indexEntry) {
  return Astro.redirect('/');
}

const { Content } = await indexEntry.render();

// Get breadcrumb context for this page
const breadcrumb = await getBreadcrumbContext('/get-started');
---

<DocsLayout title="Get Started" section={breadcrumb.section} item={breadcrumb.item}>
  <div class="docs-prose">
    <Content components={markdownComponents} />
  </div>
</DocsLayout>
