---
/**
 * Blocks Index Page
 *
 * Same layout as Components: Overview with block cards and Status tab.
 */

import DocsLayout from '../../layouts/DocsLayout.astro';
import { getCollection } from 'astro:content';
import { getBreadcrumbContext } from '../../lib/content';
import { createI18nContext } from '../../lib/i18n';
import Tabs from '../../components/docs/Tabs.astro';
import ComponentsStatusTable from '../../components/docs/ComponentsStatusTable.astro';
import { blockStatusData } from '../../data/block-status';

const allContent = await getCollection('v1-en');

const blocks = allContent.filter((item) => {
  const id = item.id || '';
  const parts = id.split('/');
  return parts[0] === 'blocks' && parts.length > 1 && !parts[1].startsWith('index.');
});

const breadcrumb = await getBreadcrumbContext('/blocks');
const i18n = createI18nContext('en');

const blocksByCategory = blocks.reduce((acc, block) => {
  const category = block.data.category || 'other';
  if (!acc[category]) acc[category] = [];
  acc[category].push(block);
  return acc;
}, {} as Record<string, typeof blocks>);

const categoryLabels: Record<string, string> = {
  feedback: 'Feedback',
  layout: 'Layout',
  form: 'Form',
  navigation: 'Navigation',
  other: 'Other',
};
---

<DocsLayout
  title="Blocks"
  description="Composable UI blocks combining multiple components for common use cases."
  section={breadcrumb.section}
  item={breadcrumb.item}
  language="en"
  i18n={i18n}
>
  <h1 class="!text-3xl font-medium text-lg mb-1.5">Blocks</h1>
  <p class="text-sm text-muted mb-8 mt-4">
    Composable UI blocks combining multiple components for common use cases.
  </p>

  <Tabs>
    <Fragment slot="overview">
      {Object.entries(blocksByCategory).map(([category, items]) => (
        <section class="mb-10">
          <h2 class="text-xl font-sans font-medium mb-4">
            {categoryLabels[category] || category}
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            {items.map((block) => {
              const name = block.id.replace(/\.(md|mdx)$/, '').split('/').pop() || block.id;
              return (
                <a
                  href={`/blocks/${name}`}
                  class="group block p-4 border border-default rounded-lg hover:border-default-hover transition-colors bg-surface"
                >
                  <div class="flex items-center justify-between mb-2">
                    <h3 class="font-medium font-sans text-default group-hover:text-primary-700">
                      {block.data.title}
                    </h3>
                    {block.data.status && (
                      <span
                        class={`text-xs px-2 py-0.5 rounded-full ${
                          block.data.status === 'stable'
                            ? 'bg-emerald-50 text-emerald-700'
                            : block.data.status === 'beta'
                              ? 'bg-blue-50 text-blue-700'
                              : block.data.status === 'deprecated'
                                ? 'bg-amber-50 text-warning'
                                : 'bg-gray-50 text-gray-600'
                        }`}
                      >
                        {block.data.status}
                      </span>
                    )}
                  </div>
                  <p class="text-sm font-sans text-muted line-clamp-2">
                    {block.data.description}
                  </p>
                </a>
              );
            })}
          </div>
        </section>
      ))}
    </Fragment>

    <Fragment slot="status">
      <ComponentsStatusTable
        components={blockStatusData}
        caption="Track the progress of each block across design and development."
      />
    </Fragment>
  </Tabs>
</DocsLayout>
