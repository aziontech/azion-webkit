---
/**
 * Playground Demo Page (English)
 * 
 * Demonstrates the interactive playground system with multiple components.
 * This page serves as a sandbox for exploring component props interactively.
 * Uses the same layouts as PT routes, with language='en' default
 */

import DocsLayout from '../../layouts/DocsLayout.astro';
import { Playground } from '../../components/playground';
import { buttonProps } from '../../components/demo/props-metadata';
import { createI18nContext } from '../../lib/i18n';

// Create i18n context for English (default)
const i18n = createI18nContext('en');
---

<DocsLayout title="Playground - Azion Design System" language="en" i18n={i18n}>
  <div class="playground-page">
    <!-- Page Header -->
    <div class="playground-page__header">
      <h1 class="text-3xl font-medium text-gray-900">Playground</h1>
      <p class="mt-2 text-lg text-gray-600">
        Explore Design System components interactively. Adjust props and see live changes.
      </p>
    </div>

    <!-- Usage Guide -->
    <section class="playground-guide mb-12">
      <h2 class="text-xl font-medium text-gray-900 mb-4">How to Use</h2>
      
      <div class="playground-guide__content">
        <div class="playground-guide__item">
          <h3 class="text-sm font-medium text-gray-700">1. Adjust Props</h3>
          <p class="mt-1 text-sm text-gray-600">
            Use the controls on the right to modify component props. Changes are reflected immediately in the preview.
          </p>
        </div>
        
        <div class="playground-guide__item">
          <h3 class="text-sm font-medium text-gray-700">2. Preview Changes</h3>
          <p class="mt-1 text-sm text-gray-600">
            The preview area shows the component with your current prop values. Try different combinations!
          </p>
        </div>
        
        <div class="playground-guide__item">
          <h3 class="text-sm font-medium text-gray-700">3. Copy Code</h3>
          <p class="mt-1 text-sm text-gray-600">
            The code panel shows the generated Vue template code. Click "Copy" to use it in your project.
          </p>
        </div>
        
        <div class="playground-guide__item">
          <h3 class="text-sm font-medium text-gray-700">4. Reset</h3>
          <p class="mt-1 text-sm text-gray-600">
            Click "Reset" in the controls panel to restore default prop values.
          </p>
        </div>
      </div>
    </section>

    <!-- Button Playground -->
    <section class="playground-section">
      <div class="playground-section__header">
        <h2 class="text-xl font-medium text-gray-900">Button</h2>
        <p class="mt-1 text-sm text-gray-600">
          Buttons trigger actions and events when users interact with them.
        </p>
      </div>
      
      <Playground
        client:load
        component-name="AzButton"
        props={buttonProps}
        slot-content="Button"
      />
    </section>
  </div>
</DocsLayout>

<style>
  .playground-page {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem;
  }

  .playground-page__header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid #e5e7eb;
  }

  .playground-section {
    margin-bottom: 3rem;
  }

  .playground-section__header {
    margin-bottom: 1rem;
  }

  .playground-guide {
    margin-top: 3rem;
    padding: 1.5rem;
    background-color: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 0.5rem;
  }

  .playground-guide__content {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 640px) {
    .playground-guide__content {
      grid-template-columns: 1fr;
    }
  }

  .playground-guide__item {
    padding: 1rem;
    background-color: #ffffff;
    border-radius: 0.375rem;
  }
</style>
