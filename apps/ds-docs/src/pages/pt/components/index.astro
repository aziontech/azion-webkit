---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import { getCollection } from 'astro:content';
import { getBreadcrumbContext } from '../../../lib/content';
import { createI18nContext } from '../../../lib/i18n';
import Tabs from '../../../components/docs/Tabs.astro';
import ComponentsStatusTable from '../../../components/docs/ComponentsStatusTable.astro';
import { componentStatusData } from '../../../data/component-status';

/**
 * Portuguese Components Index Page
 * 
 * Lists all available components in the design system with tabs for
 * Overview (component cards) and Status (progress tracking).
 */

const allContent = await getCollection('v1-pt');

// Filter to only get components (not other content types)
const componentItems = allContent.filter(item => {
  const id = item.id || '';
  const idParts = id.split('/');
  return idParts[0] === 'components' && idParts.length > 1 && !idParts[1].startsWith('index.');
});

// Get breadcrumb context for this page
const breadcrumb = await getBreadcrumbContext('/pt/components');

// Create i18n context for Portuguese
const i18n = createI18nContext('pt');

// Group components by category
const componentsByCategory = componentItems.reduce((acc, component) => {
  const category = component.data.category || 'other';
  if (!acc[category]) {
    acc[category] = [];
  }
  acc[category].push(component);
  return acc;
}, {} as Record<string, typeof componentItems>);

const categoryLabels: Record<string, string> = {
  form: 'Componentes de Formulário',
  navigation: 'Componentes de Navegação',
  feedback: 'Componentes de Feedback',
  'data-display': 'Componentes de Exibição de Dados',
  layout: 'Componentes de Layout',
  utility: 'Componentes Utilitários',
};
---

<DocsLayout 
  title="Componentes" 
  description="Biblioteca de componentes Vue.js do Azion Design System."
  section={breadcrumb.section} 
  item={breadcrumb.item}
  language="pt"
  i18n={i18n}
>
  <h1>Componentes</h1>
  <p class="text-xl text-text-secondary mb-8">
    Explore nossa biblioteca de componentes Vue.js, projetados para a plataforma Azion.
  </p>
  
  <Tabs>
    <Fragment slot="overview">
      {Object.entries(componentsByCategory).map(([category, items]) => (
        <section class="mb-10">
          <h2 class="text-xl font-medium mb-4">{categoryLabels[category] || category}</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            {items.map((component) => {
              // Extract component name from id (e.g., 'components/button.mdx' -> 'button')
              const componentName = component.id.replace(/\.(md|mdx)$/, '').split('/').pop() || component.id;
              return (
                <a
                  href={`/pt/components/${componentName}`}
                  class="group p-4 border border-gray-200 rounded-lg hover:border-primary-300 hover:bg-primary-50/50 transition-colors"
                >
                  <div class="flex items-center justify-between mb-2">
                    <h3 class="font-medium text-text-primary group-hover:text-primary-700">
                      {component.data.title}
                    </h3>
                    {component.data.status && (
                      <span class={`text-xs px-2 py-0.5 rounded-full ${
                        component.data.status === 'stable' ? 'bg-emerald-50 text-emerald-700' :
                        component.data.status === 'beta' ? 'bg-blue-50 text-blue-700' :
                        component.data.status === 'deprecated' ? 'bg-amber-50 text-amber-700' :
                        'bg-gray-50 text-gray-600'
                      }`}>
                        {component.data.status === 'stable' ? 'Estável' :
                         component.data.status === 'beta' ? 'Beta' :
                         component.data.status === 'deprecated' ? 'Descontinuado' :
                         component.data.status}
                      </span>
                    )}
                  </div>
                  <p class="text-sm text-text-secondary line-clamp-2">
                    {component.data.description}
                  </p>
                </a>
              );
            })}
          </div>
        </section>
      ))}
    </Fragment>
    
    <Fragment slot="status">
      <ComponentsStatusTable 
        components={componentStatusData}
        caption="Acompanhe o progresso de cada componente entre design e desenvolvimento. Os componentes estão ordenados por status de lançamento."
      />
    </Fragment>
  </Tabs>
</DocsLayout>
