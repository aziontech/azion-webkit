---
/**
 * Portuguese Documentation Catch-All Route
 * 
 * Handles all Portuguese documentation URLs under /pt/
 * 
 * URL patterns:
 * - /pt/get-started
 * - /pt/get-started/installation
 * - /pt/foundations
 * - /pt/foundations/color
 * - /pt/components
 * - /pt/components/button
 */

import { getCollection } from 'astro:content';
import ComponentPageLayout from '../../layouts/ComponentPageLayout.astro';
import DocPageLayout from '../../layouts/DocPageLayout.astro';
import { getBreadcrumbContext } from '../../lib/content';
import { markdownComponents } from '../../components/docs';
import { createI18nContext } from '../../lib/i18n';

// Define static paths for all Portuguese content
export async function getStaticPaths() {
  const paths: Array<{
    params: { path: string };
    props: { entry: any; section: string };
  }> = [];

  // Get all Portuguese content from the nested structure
  const ptContent = await getCollection('pt');
  
  for (const entry of ptContent) {
    // The slug in 'pt' collection includes the subfolder structure
    // e.g., 'get-started/index', 'components/button'
    const slugParts = entry.slug.split('/');
    
    // Build the path parameter
    // For 'get-started/index' -> path: 'get-started'
    // For 'components/button' -> path: 'components/button'
    let pathValue: string;
    if (slugParts[slugParts.length - 1] === 'index') {
      // Remove 'index' from the end
      pathValue = slugParts.slice(0, -1).join('/') || 'index';
    } else {
      pathValue = entry.slug;
    }
    
    // Determine the section (first part of the path)
    const section = slugParts[0];
    
    paths.push({
      params: { path: pathValue },
      props: { entry, section },
    });
  }

  return paths;
}

const { entry, section } = Astro.props;
const { Content } = await entry.render();

// Get breadcrumb context
const fullPath = `/pt/${entry.slug === 'index' ? '' : entry.slug.replace(/\/index$/, '')}`;
const breadcrumb = await getBreadcrumbContext(fullPath);

// Extract frontmatter data
const data = entry.data;

// Create i18n context for Portuguese
const i18n = createI18nContext('pt');

// Determine which layout to use based on section
const isComponentPage = section === 'components' && data.type === 'component';
---

{isComponentPage ? (
  <ComponentPageLayout
    title={data.title}
    description={data.description}
    section={breadcrumb.section}
    item={breadcrumb.item}
    status={data.status}
    category={data.category}
    component={data.component}
    source={data.source}
    storybook={data.storybook}
    figma={data.figma}
    related={data.related}
    anatomy={data.anatomy}
    accessibility={data.accessibility}
    api={data.api}
    language="pt"
    i18n={i18n}
  >
    <Content components={markdownComponents} />
  </ComponentPageLayout>
) : (
  <DocPageLayout
    title={data.title}
    description={data.description}
    section={breadcrumb.section}
    item={breadcrumb.item}
    language="pt"
    i18n={i18n}
  >
    <Content components={markdownComponents} />
  </DocPageLayout>
)}
