---
/**
 * Página inicial (Português)
 *
 * Landing page da documentação do Azion Design System.
 * Usa os mesmos layouts das rotas PT, com language='pt'
 */

import DocsLayout from '../../layouts/DocsLayout.astro';
import { createI18nContext } from '../../lib/i18n';

// Contexto i18n para português (pt-BR)
const i18n = createI18nContext('pt');

const heroLinks = [
  { href: '/pt/get-started/installation', label: 'Instalação', description: 'Comece com a instalação' },
  { href: '/pt/components', label: 'Componentes', description: 'Explore nossa biblioteca de componentes' },
  { href: '/pt/foundations', label: 'Fundamentos', description: 'Conheça os princípios de design' },
];

const features = [
  {
    icon: '🎨',
    title: 'Design Tokens',
    description: 'Linguagem de design consistente com tokens para cores, tipografia, espaçamento e mais.',
  },
  {
    icon: '🧩',
    title: 'Componentes',
    description: 'Componentes Vue prontos para produção, pensados em acessibilidade.',
  },
  {
    icon: '📱',
    title: 'Responsivo',
    description: 'Componentes que funcionam em todos os tamanhos de tela e dispositivos.',
  },
  {
    icon: '♿',
    title: 'Acessível',
    description: 'Componentes em conformidade com WCAG, com navegação por teclado e suporte a leitores de tela.',
  },
];
---

<DocsLayout title="Início" language="pt" i18n={i18n}>
  <!-- Hero Section -->
  <section class="mb-12">
    <h1 class="text-4xl font-medium tracking-tight mb-4">
      Azion Design System
    </h1>
    <p class="text-default text-muted mb-8 max-w-2xl">
      Construa interfaces de usuário consistentes, acessíveis e bonitas com nosso design system.
      Pensado para a plataforma de edge computing da Azion.
    </p>
    
    <div class="flex flex-wrap gap-3">
      {heroLinks.map((link) => (
        <a
          href={link.href}
          class="group px-6 py-4 bg-layer1 hover:bg-layer1-hover border border-default hover:border-default-hover rounded-lg transition-colors"
        >
          <span class="block mb-1 font-medium text-default">
            {link.label}
          </span>
          <span class="block text-xs text-muted">
            {link.description}
          </span>
        </a>
      ))}
    </div>
  </section>
  
  <!-- Features Section -->
  <!-- <section class="mb-12">
    <h2 class="text-2xl font-medium mb-6">Por que usar nosso Design System?</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {features.map((feature) => (
        <div class="p-6 bg-surface-subtle rounded-lg">
          <span class="text-3xl mb-3 block">{feature.icon}</span>
          <h3 class="text-lg font-medium mb-2">{feature.title}</h3>
          <p class="text-muted">{feature.description}</p>
        </div>
      ))}
    </div>
  </section> -->
  
  <!-- Quick Start Section -->
  <section class="mb-12">
    <h2 class="text-2xl font-medium mb-6">Início rápido</h2>
    <div class="bg-surface-900 rounded-lg p-6">
      <pre class="text-sm text-gray-100"><code class="!font-code">npm install @aziontech/components @aziontech/icons @aziontech/theme</code></pre>
    </div>
  </section>
  
  <!-- Status Section -->
  <section>
    <h2 class="text-2xl font-medium mb-6">Status do projeto</h2>
    <div class="space-y-4">
      <div class="flex items-center gap-3">
        <span class="inline-flex font-mono items-center gap-1.5 px-2.5 py-0.5 text-xs font-medium rounded-full bg-green-500/20 dark:text-green-500 text-green-700 border border-green-500/50">
          ✓ Estável
        </span>
        <span class="text-muted">Pacote de ícones pronto para produção</span>
      </div>
      <div class="flex items-center gap-3">
        <span class="inline-flex font-mono items-center gap-1.5 px-2.5 py-0.5 text-xs font-medium rounded-full bg-green-500/20 dark:text-green-500 text-green-700 border border-green-500/50">
          ✓ Estável
        </span>
        <span class="text-muted">Pacote de tokens de cores pronto para produção</span>
      </div>
      <div class="flex items-center gap-3">
        <span class="inline-flex font-mono items-center gap-1.5 px-2.5 py-0.5 text-xs font-medium rounded-full bg-gray-500/20 dark:text-gray-500 text-gray-600 border border-gray-500/50">
          ○ Planejado
        </span>
        <span class="text-muted">Tokens de tipografia e espaçamento em breve</span>
      </div>
      <div class="flex items-center gap-3">
        <span class="inline-flex font-mono items-center gap-1.5 px-2.5 py-0.5 text-xs font-medium rounded-full yellow-500/20 dark:text-yellow-500 text-yellow-600 border border-yellow-500/50">
          ○ Em progresso
        </span>
        <span class="text-muted">Pacote de componentes em breve</span>      </div>
    </div>
  </section>
</DocsLayout>
