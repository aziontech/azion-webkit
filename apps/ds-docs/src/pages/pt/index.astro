---
import DocsLayout from '../../layouts/DocsLayout.astro';

/**
 * Portuguese Homepage
 * 
 * Landing page for the Azion Design System documentation in Portuguese.
 */

const heroLinks = [
  { href: '/pt/components', label: 'Componentes', description: 'Explore nossa biblioteca de componentes' },
  { href: '/pt/foundations', label: 'Fundamentos', description: 'Aprenda os princípios de design' },
];

const features = [
  {
    icon: '🎨',
    title: 'Design Tokens',
    description: 'Linguagem de design consistente com tokens para cores, tipografia, espaçamento e mais.',
  },
  {
    icon: '🧩',
    title: 'Componentes',
    description: 'Componentes Vue prontos para produção construídos com acessibilidade em mente.',
  },
  {
    icon: '📱',
    title: 'Responsivo',
    description: 'Componentes que funcionam perfeitamente em todos os tamanhos de tela e dispositivos.',
  },
  {
    icon: '♿',
    title: 'Acessível',
    description: 'Componentes compatíveis com WCAG com navegação por teclado e suporte a leitores de tela.',
  },
];
---

<DocsLayout title="Início">
  <!-- Hero Section -->
  <section class="mb-12">
    <h1 class="text-4xl font-bold tracking-tight mb-4">
      Azion Design System
    </h1>
    <p class="text-xl text-text-secondary mb-8 max-w-2xl">
      Construa interfaces de usuário consistentes, acessíveis e bonitas com nosso design system abrangente. 
      Projetado para a plataforma de edge computing da Azion.
    </p>
    
    <div class="flex flex-wrap gap-4">
      {heroLinks.map((link) => (
        <a
          href={link.href}
          class="group px-6 py-4 bg-surface-subtle hover:bg-primary-50 border border-gray-200 hover:border-primary-200 rounded-lg transition-colors"
        >
          <span class="block text-lg font-medium text-text-primary group-hover:text-primary-700">
            {link.label}
          </span>
          <span class="block text-sm text-text-secondary">
            {link.description}
          </span>
        </a>
      ))}
    </div>
  </section>
  
  <!-- Features Section -->
  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-6">Por que usar nosso Design System?</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {features.map((feature) => (
        <div class="p-6 bg-surface-subtle rounded-lg">
          <span class="text-3xl mb-3 block">{feature.icon}</span>
          <h3 class="text-lg font-medium mb-2">{feature.title}</h3>
          <p class="text-text-secondary">{feature.description}</p>
        </div>
      ))}
    </div>
  </section>
  
  <!-- Quick Start Section -->
  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-6">Início Rápido</h2>
    <div class="bg-gray-900 rounded-lg p-6">
      <p class="text-gray-400 mb-4">Instale os pacotes do design system:</p>
      <pre class="text-sm text-gray-100"><code>npm install @aziontech/components @aziontech/icons @aziontech/theme</code></pre>
    </div>
  </section>
  
  <!-- Status Section -->
  <section>
    <h2 class="text-2xl font-semibold mb-6">Status do Projeto</h2>
    <div class="space-y-4">
      <div class="flex items-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 text-xs font-medium rounded-full bg-emerald-50 text-emerald-700 border border-emerald-200">
          ✓ Estável
        </span>
        <span class="text-text-secondary">O pacote de ícones está pronto para produção</span>
      </div>
      <div class="flex items-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 text-xs font-medium rounded-full bg-blue-50 text-blue-700 border border-blue-200">
          β Beta
        </span>
        <span class="text-text-secondary">Pacote de componentes em desenvolvimento ativo</span>
      </div>
      <div class="flex items-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 text-xs font-medium rounded-full bg-gray-50 text-gray-600 border border-gray-200">
          ○ Planejado
        </span>
        <span class="text-text-secondary">Pacote de tema em breve</span>
      </div>
    </div>
  </section>
</DocsLayout>
