---
/**
 * Patterns Dynamic Routes (English)
 *
 * Handles all pages under /patterns/[slug]. Excludes index so /patterns is served by index.astro.
 * Uses PatternPageLayout (shell + header + prose, no tabs).
 */

import { getCollection, render } from 'astro:content';
import PatternPageLayout from '../../layouts/PatternPageLayout.astro';
import { getBreadcrumbContext } from '../../lib/content';
import { markdownComponents } from '../../components/docs';
import { createI18nContext } from '../../lib/i18n';
import type { PatternFrontmatter } from '../../content/config';

export async function getStaticPaths() {
  const allContent = await getCollection('v1-en');
  const entries = allContent.filter((entry) => {
    const id = entry.id || '';
    if (!id.startsWith('patterns/')) return false;
    const slug = id.replace('patterns/', '').replace(/\.(md|mdx)$/, '');
    return slug !== 'index';
  });
  return entries.map((entry) => ({
    params: { slug: entry.id.replace('patterns/', '').replace(/\.(md|mdx)$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const entryId = entry.id.replace(/\.(md|mdx)$/, '');
const slugFromId = entryId.replace('patterns/', '');
const breadcrumb = await getBreadcrumbContext(`/patterns/${slugFromId}`);
const i18n = createI18nContext('en');
const data = entry.data as PatternFrontmatter;
---

<PatternPageLayout
  title={data.title}
  description={data.description}
  section={breadcrumb.section}
  item={breadcrumb.item}
  status={data.status}
  category={data.category}
  related={data.related || []}
  language="en"
  i18n={i18n}
>
  <Content components={markdownComponents} />
</PatternPageLayout>
