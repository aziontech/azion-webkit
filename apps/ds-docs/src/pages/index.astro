---
import DocsLayout from '../layouts/DocsLayout.astro';

/**
 * Homepage
 * 
 * Landing page for the Azion Design System documentation.
 */

const heroLinks = [
  { href: '/get-started/installation', label: 'Installation', description: 'Get started with installation' },
  { href: '/components', label: 'Components', description: 'Explore our component library' },
  { href: '/foundations', label: 'Foundations', description: 'Learn the design principles' },
];

const features = [
  {
    icon: '🎨',
    title: 'Design Tokens',
    description: 'Consistent design language with tokens for colors, typography, spacing, and more.',
  },
  {
    icon: '🧩',
    title: 'Components',
    description: 'Production-ready Vue components built with accessibility in mind.',
  },
  {
    icon: '📱',
    title: 'Responsive',
    description: 'Components that work seamlessly across all screen sizes and devices.',
  },
  {
    icon: '♿',
    title: 'Accessible',
    description: 'WCAG compliant components with keyboard navigation and screen reader support.',
  },
];
---

<DocsLayout title="Home">
  <!-- Hero Section -->
  <section class="mb-12">
    <h1 class="text-4xl font-bold tracking-tight mb-4">
      Azion Design System
    </h1>
    <p class="text-xl text-text-secondary mb-8 max-w-2xl">
      Build consistent, accessible, and beautiful user interfaces with our comprehensive design system. 
      Designed for Azion's edge computing platform.
    </p>
    
    <div class="flex flex-wrap gap-4">
      {heroLinks.map((link) => (
        <a
          href={link.href}
          class="group px-6 py-4 bg-surface-subtle hover:bg-primary-50 border border-gray-200 hover:border-primary-200 rounded-lg transition-colors"
        >
          <span class="block text-lg font-medium text-text-primary group-hover:text-primary-700">
            {link.label}
          </span>
          <span class="block text-sm text-text-secondary">
            {link.description}
          </span>
        </a>
      ))}
    </div>
  </section>
  
  <!-- Features Section -->
  <section class="mb-12">
    <h2 class="text-2xl font-medium mb-6">Why use our Design System?</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {features.map((feature) => (
        <div class="p-6 bg-surface-subtle rounded-lg">
          <span class="text-3xl mb-3 block">{feature.icon}</span>
          <h3 class="text-lg font-medium mb-2">{feature.title}</h3>
          <p class="text-text-secondary">{feature.description}</p>
        </div>
      ))}
    </div>
  </section>
  
  <!-- Quick Start Section -->
  <section class="mb-12">
    <h2 class="text-2xl font-medium mb-6">Quick Start</h2>
    <div class="bg-gray-900 rounded-lg p-6">
      <p class="text-gray-400 mb-4">Install the design system packages:</p>
      <pre class="text-sm text-gray-100"><code class="!font-code">npm install @aziontech/components @aziontech/icons @aziontech/theme</code></pre>
    </div>
  </section>
  
  <!-- Status Section -->
  <section>
    <h2 class="text-2xl font-medium mb-6">Project Status</h2>
    <div class="space-y-4">
      <div class="flex items-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 text-xs font-medium rounded-full bg-emerald-50 text-emerald-700 border border-emerald-200">
          ✓ Stable
        </span>
        <span class="text-text-secondary">Icons package is production-ready</span>
      </div>
      <div class="flex items-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 text-xs font-medium rounded-full bg-blue-50 text-blue-700 border border-blue-200">
          β Beta
        </span>
        <span class="text-text-secondary">Components package in active development</span>
      </div>
      <div class="flex items-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 text-xs font-medium rounded-full bg-gray-50 text-gray-600 border border-gray-200">
          ○ Planned
        </span>
        <span class="text-text-secondary">Theme package coming soon</span>
      </div>
    </div>
  </section>
</DocsLayout>
