---
/**
 * Homepage (English)
 * 
 * Landing page for the Azion Design System documentation.
 * Uses the same layouts as PT routes, with language='en' default
 */

import DocsLayout from '../layouts/DocsLayout.astro';
import { createI18nContext } from '../lib/i18n';

// Create i18n context for English (default)
const i18n = createI18nContext('en');

const heroLinks = [
  { href: '/get-started/installation', label: 'Installation', description: 'Get started with installation' },
  { href: '/components', label: 'Components', description: 'Explore our component library' },
  { href: '/foundations', label: 'Foundations', description: 'Learn the design principles' },
];

const features = [
  {
    icon: '🎨',
    title: 'Design Tokens',
    description: 'Consistent design language with tokens for colors, typography, spacing, and more.',
  },
  {
    icon: '🧩',
    title: 'Components',
    description: 'Production-ready Vue components built with accessibility in mind.',
  },
  {
    icon: '📱',
    title: 'Responsive',
    description: 'Components that work seamlessly across all screen sizes and devices.',
  },
  {
    icon: '♿',
    title: 'Accessible',
    description: 'WCAG compliant components with keyboard navigation and screen reader support.',
  },
];
---

<DocsLayout title="Home" language="en" i18n={i18n}>
  <!-- Hero Section -->
  <section class="mb-12">
    <h1 class="text-4xl font-medium tracking-tight mb-4">
      Azion Design System
    </h1>
    <p class="text-default text-muted mb-8 max-w-2xl">
      Build consistent, accessible, and beautiful user interfaces with our comprehensive design system. 
      Designed for Azion's edge computing platform.
    </p>
    
    <div class="flex flex-wrap gap-3">
      {heroLinks.map((link) => (
        <a
          href={link.href}
          class="group px-6 py-4 bg-layer1 hover:bg-layer1-hover border border-default hover:border-default-hover rounded-lg transition-colors"
        >
          <span class="block mb-1 font-medium text-default">
            {link.label}
          </span>
          <span class="block text-xs text-muted">
            {link.description}
          </span>
        </a>
      ))}
    </div>
  </section>
  
  <!-- Features Section -->
  <!-- <section class="mb-12">
    <h2 class="text-2xl font-medium mb-6">Why use our Design System?</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {features.map((feature) => (
        <div class="p-6 bg-surface-subtle rounded-lg">
          <span class="text-3xl mb-3 block">{feature.icon}</span>
          <h3 class="text-lg font-medium mb-2">{feature.title}</h3>
          <p class="text-muted">{feature.description}</p>
        </div>
      ))}
    </div>
  </section> -->
  
  <!-- Quick Start Section -->
  <section class="mb-12">
    <h2 class="text-2xl font-medium mb-6">Quick Start</h2>
    <div class="bg-surface-900 rounded-lg p-6">
      <pre class="text-sm text-gray-100"><code class="!font-code">npm install @aziontech/components @aziontech/icons @aziontech/theme</code></pre>
    </div>
  </section>
  
  <!-- Status Section -->
  <section>
    <h2 class="text-2xl font-medium mb-6">Project Status</h2>
    <div class="space-y-4">
      <div class="flex items-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 text-xs font-medium rounded-full bg-green-500/20 dark:text-green-500 text-green-700 border border-green-500/50">
          ✓ Stable
        </span>
        <span class="text-muted">Icons package is production-ready</span>
      </div>
      <div class="flex items-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 text-xs font-medium rounded-full bg-gray-500/20 dark:text-gray-500 text-gray-600 border border-gray-500/50">
          ○ Planned
        </span>
        <span class="text-muted">Tokens package coming soon</span>
      </div>
      <div class="flex items-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 text-xs font-medium rounded-full bg-gray-500/20 dark:text-gray-500 text-gray-600 border border-gray-500/50">
          ○ Planned
        </span>
        <span class="text-muted">Components package coming soon</span>
      </div>
    </div>
  </section>
</DocsLayout>
