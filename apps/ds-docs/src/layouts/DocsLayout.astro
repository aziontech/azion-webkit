---
import '../styles/global.css';
import SearchModal from '../components/search/SearchModal.vue';

/**
 * DocsLayout
 * 
 * Base layout for all documentation pages.
 * Provides the shell structure with sidebar navigation and header.
 */

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Azion Design System Documentation' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Azion Design System</title>
  </head>
  <body class="min-h-screen bg-surface">
    <div class="docs-layout flex">
      <!-- Sidebar Navigation -->
      <aside class="docs-sidebar w-64 h-screen sticky top-0 border-r border-gray-200 bg-surface overflow-y-auto scrollbar-hide">
        <div class="p-4">
          <!-- Logo/Brand -->
          <div class="mb-6">
            <a href="/" class="flex items-center gap-2 text-lg font-semibold text-text-primary">
              <span class="text-primary-600">Azion</span>
              <span class="text-text-secondary">Design System</span>
            </a>
          </div>
          
          <!-- Navigation Placeholder -->
          <nav class="space-y-1">
            <a href="/get-started" class="nav-link block px-3 py-2 text-sm rounded-md hover:bg-surface-subtle text-text-secondary hover:text-text-primary">
              Get Started
            </a>
            <a href="/foundations" class="nav-link block px-3 py-2 text-sm rounded-md hover:bg-surface-subtle text-text-secondary hover:text-text-primary">
              Foundations
            </a>
            <a href="/tokens" class="nav-link block px-3 py-2 text-sm rounded-md hover:bg-surface-subtle text-text-secondary hover:text-text-primary">
              Tokens
            </a>
            <a href="/components" class="nav-link block px-3 py-2 text-sm rounded-md bg-primary-50 text-primary-700 font-medium">
              Components
            </a>
            <a href="/blocks" class="nav-link block px-3 py-2 text-sm rounded-md hover:bg-surface-subtle text-text-secondary hover:text-text-primary">
              Blocks
            </a>
            <a href="/patterns" class="nav-link block px-3 py-2 text-sm rounded-md hover:bg-surface-subtle text-text-secondary hover:text-text-primary">
              Patterns
            </a>
            <a href="/templates" class="nav-link block px-3 py-2 text-sm rounded-md hover:bg-surface-subtle text-text-secondary hover:text-text-primary">
              Templates
            </a>
            <a href="/icons" class="nav-link block px-3 py-2 text-sm rounded-md hover:bg-surface-subtle text-text-secondary hover:text-text-primary">
              Icons
            </a>
            <a href="/contributing" class="nav-link block px-3 py-2 text-sm rounded-md hover:bg-surface-subtle text-text-secondary hover:text-text-primary">
              Contributing
            </a>
          </nav>
        </div>
      </aside>
      
      <!-- Main Content Area -->
      <main class="docs-main flex-1 min-h-screen">
        <!-- Header -->
        <header class="docs-header h-16 sticky top-0 z-10 border-b border-gray-200 bg-surface/95 backdrop-blur">
          <div class="flex items-center justify-between h-full px-6">
            <!-- Breadcrumb placeholder -->
            <div class="flex items-center gap-2 text-sm">
              <span class="text-text-muted">Documentation</span>
              <span class="text-text-muted">/</span>
              <span class="text-text-primary font-medium">Components</span>
            </div>
            
            <!-- Header actions -->
            <div class="flex items-center gap-4">
              <!-- Search button -->
              <button 
                id="search-button"
                class="flex items-center gap-2 px-3 py-1.5 text-sm text-text-secondary bg-surface-subtle rounded-md hover:bg-gray-100"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
                <span>Search</span>
                <kbd class="hidden sm:inline-flex px-1.5 py-0.5 text-xs bg-gray-200 rounded">⌘K</kbd>
              </button>
              
              <!-- GitHub link -->
              <a 
                href="https://github.com/aziontech/webkit" 
                target="_blank" 
                rel="noopener noreferrer"
                class="text-text-secondary hover:text-text-primary"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
                </svg>
              </a>
            </div>
          </div>
        </header>
        
        <!-- Content -->
        <div class="docs-content px-6 py-8 max-w-docs-content">
          <slot />
        </div>
      </main>
    </div>
    
    <!-- Search Modal - rendered at body level for proper positioning -->
    <SearchModal client:only="vue" />
  </body>
</html>

<script>
  // Global keyboard shortcut for search
  document.addEventListener('keydown', (event) => {
    if ((event.metaKey || event.ctrlKey) && event.key === 'k') {
      event.preventDefault();
      // The SearchModal component handles the state via useSearch composable
      // We dispatch a custom event that the modal listens to
      document.dispatchEvent(new CustomEvent('toggle-search'));
    }
  });
  
  // Click handler for search button
  document.getElementById('search-button')?.addEventListener('click', () => {
    document.dispatchEvent(new CustomEvent('toggle-search'));
  });
</script>

<style>
  .docs-layout {
    min-height: 100vh;
  }
  
  .docs-sidebar {
    flex-shrink: 0;
  }
  
  /* Active nav link */
  .nav-link.active {
    @apply bg-primary-50 text-primary-700 font-medium;
  }
</style>
