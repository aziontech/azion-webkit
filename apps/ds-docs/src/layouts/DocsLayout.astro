---
import '../styles/global.css';
// Import Azion Icons - icon font library (azionicons + primeicons)
import '@aziontech/icons';
import SearchModal from '../components/search/SearchModal.vue';
import DocsSidebar from '../components/docs/DocsSidebar.vue';
import DocsHeader from '../components/docs/DocsHeader.vue';
import LanguageSwitcher from '../components/docs/LanguageSwitcher.vue';
import { getNavigationTree, getBreadcrumbContext } from '../lib/content';
import type { Section, NavItem } from '../lib/content/types';
import { createI18nContext, type I18nContext } from '../lib/i18n';
import { getDefaultLanguage, isSupportedLanguage, getAllLanguages, getLanguageLabel } from '../config';

/**
 * DocsLayout
 * 
 * Base layout for all documentation pages.
 * Provides the shell structure with sidebar navigation and header.
 * Supports internationalization (i18n) with language switching.
 */

interface Props {
  title: string;
  description?: string;
  /** Current section for breadcrumb */
  section?: Section | null;
  /** Current page item for breadcrumb */
  item?: NavItem | null;
  /** Current language code */
  language?: string;
  /** i18n context for translations */
  i18n?: I18nContext;
}

const { 
  title, 
  description = 'Azion Design System Documentation', 
  section, 
  item,
  language = 'en',
  i18n: i18nProp
} = Astro.props;

// Create i18n context if not provided
const i18n = i18nProp ?? createI18nContext(language);

// Get navigation tree for sidebar
const navigation = await getNavigationTree();

// Get current path for active state
const currentPath = Astro.url.pathname;

// Determine the language for the HTML lang attribute
const htmlLang = isSupportedLanguage(language) ? language : getDefaultLanguage();

// Build alternate language URLs for hreflang tags
const alternateUrls: Record<string, string> = {};
const pathWithoutLang = currentPath.replace(/^\/(pt|en)/, '') || '/';
for (const lang of getAllLanguages()) {
  if (lang === getDefaultLanguage()) {
    alternateUrls[lang] = pathWithoutLang;
  } else {
    alternateUrls[lang] = `/${lang}${pathWithoutLang}`;
  }
}
---

<!DOCTYPE html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Azion Design System</title>
    
    <!-- hreflang tags for SEO -->
    {getAllLanguages().map((lang) => (
      <link 
        rel="alternate" 
        hreflang={lang} 
        href={`https://docs.azion.com${alternateUrls[lang]}`} 
      />
    ))}
    <link 
      rel="alternate" 
      hreflang="x-default" 
      href={`https://docs.azion.com${alternateUrls[getDefaultLanguage()]}`} 
    />
  </head>
  <body class="min-h-screen bg-surface">
    <div class="docs-layout flex">
      <!-- Sidebar Navigation -->
      <DocsSidebar
        client:load
        navigation={navigation}
        currentPath={currentPath}
        language={language}
      />
      
      <!-- Main Content Area -->
      <main class="docs-main flex-1 min-h-screen">
        <!-- Header with dynamic breadcrumb and language switcher -->
        <DocsHeader
          client:load
          section={section}
          item={item}
          language={language}
        />
        
        <!-- Content -->
        <div class="docs-content px-6 py-8 max-w-docs-content">
          <slot />
        </div>
      </main>
    </div>
    
    <!-- Search Modal - rendered at body level for proper positioning -->
    <SearchModal client:only="vue" />
  </body>
</html>

<script>
  // Global keyboard shortcut for search
  document.addEventListener('keydown', (event) => {
    if ((event.metaKey || event.ctrlKey) && event.key === 'k') {
      event.preventDefault();
      // The SearchModal component handles the state via useSearch composable
      // We dispatch a custom event that the modal listens to
      document.dispatchEvent(new CustomEvent('toggle-search'));
    }
  });
</script>

<style>
  .docs-layout {
    min-height: 100vh;
  }
  
  .docs-sidebar {
    flex-shrink: 0;
  }
  
  .docs-content {
    max-width: 80rem;
  }
</style>
