{
  "name": "@aziontech/webkit",
  "version": "0.0.2",
  "description": "Reusable UI components and design system utilities for building Azion web interfaces.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aziontech/webkit.git",
    "directory": "packages/webkit"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist/",
    "clean:dts": "rm -rf src/core/**/*.d.ts src/core/**/*.d.ts.map",
    "build:dts": "vue-tsc --declaration --emitDeclarationOnly",
    "build": "npm run clean:dts; npm run build:dts",
    "publish": "npm publish",
    "pack:dry": "npm pack --dry-run",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "vee-validate": "^4.15.1",
    "vue-tsc": "^3.2.5"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^10.0.1",
    "@semantic-release/exec": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^9.2.6",
    "@semantic-release/npm": "^11.0.0",
    "@semantic-release/release-notes-generator": "^12.1.0",
    "conventional-changelog-conventionalcommits": "^7.0.0",
    "semantic-release": "^23.0.0"
  },
  "files": [
    "src",
    "package.json"
  ],
  "exports": {
    "./field-auto-complete": "./src/core/field-auto-complete/field-auto-complete.vue",
    "./field-checkbox-block": "./src/core/field-checkbox-block/field-checkbox-block.vue",
    "./field-dropdown": "./src/core/field-dropdown/field-dropdown.vue",
    "./field-dropdown-icon": "./src/core/field-dropdown-icon/field-dropdown-icon.vue",
    "./field-dropdown-lazy-loader": "./src/core/field-dropdown-lazy-loader/field-dropdown-lazy-loader.vue",
    "./field-dropdown-lazy-loader-dynamic": "./src/core/field-dropdown-lazy-loader-dynamic/field-dropdown-lazy-loader-dynamic.vue",
    "./field-dropdown-lazy-loader-with-filter": "./src/core/field-dropdown-lazy-loader-with-filter/field-dropdown-lazy-loader-with-filter.vue",
    "./field-dropdown-multi-select-lazy-loader": "./src/core/field-dropdown-multi-select-lazy-loader/field-dropdown-multi-select-lazy-loader.vue",
    "./field-group-checkbox": "./src/core/field-group-checkbox/field-group-checkbox.vue",
    "./field-group-radio": "./src/core/field-group-radio/field-group-radio.vue",
    "./field-group-switch": "./src/core/field-group-switch/field-group-switch.vue",
    "./field-input-group": "./src/core/field-input-group/field-input-group.vue",
    "./field-multi-select": "./src/core/field-multi-select/field-multi-select.vue",
    "./field-number": "./src/core/field-number/field-number.vue",
    "./field-phone-number": "./src/core/field-phone-number/field-phone-number.vue",
    "./field-phone-number-country": "./src/core/field-phone-number-country/field-phone-number-country.vue",
    "./field-pick-list": "./src/core/field-pick-list/field-pick-list.vue",
    "./field-radio-block": "./src/core/field-radio-block/field-radio-block.vue",
    "./field-switch": "./src/core/field-switch/field-switch.vue",
    "./field-switch-block": "./src/core/field-switch-block/field-switch-block.vue",
    "./field-text": "./src/core/field-text/field-text.vue",
    "./field-text-area": "./src/core/field-text-area/field-text-area.vue",
    "./field-text-icon": "./src/core/field-text-icon/field-text-icon.vue",
    "./field-text-password": "./src/core/field-text-password/field-text-password.vue",
    "./label": "./src/core/label/label.vue",
